# Integration-test environment (loaded by jest.config.js via loadEnv("test")).
# @medusajs/test-utils creates a throwaway database per suite using these
# DB_* credentials — they must match the local pokenic-postgres container
# (the same medusa:medusa creds as DATABASE_URL in .env). Local dev/test
# only; never reuse these values outside docker-compose.
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=medusa
DB_PASSWORD=medusa
