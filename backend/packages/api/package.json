{
  "name": "@acme/api",
  "version": "2.1.6",
  "description": "A starter for Medusa projects.",
  "author": "Medusa (https://medusajs.com)",
  "license": "MIT",
  "exports": {
    "./_generated": {
      "types": "./.mercur/_generated/index.ts"
    }
  },
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "build": "medusa build",
    "seed": "medusa exec ./src/scripts/seed.ts",
    "deploy:init": "medusa db:migrate && medusa exec ./src/scripts/seed.ts && medusa exec ./src/scripts/print-publishable-key.ts",
    "deploy:migrate-user": "medusa db:migrate && medusa exec ./src/scripts/create-admin.ts && medusa exec ./src/scripts/seed-vip-achievements.ts",
    "start": "medusa start",
    "dev": "medusa develop",
    "test:integration:http": "node integration-tests/run-http-shards.mjs",
    "test:integration:modules": "TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit"
  },
  "dependencies": {
    "@acme/odds-math": "workspace:*",
    "@medusajs/admin-sdk": "2.17.2",
    "@medusajs/admin-shared": "2.17.2",
    "@medusajs/cli": "2.17.2",
    "@medusajs/dashboard": "2.17.2",
    "@medusajs/draft-order": "2.17.2",
    "@medusajs/framework": "2.17.2",
    "@medusajs/medusa": "2.17.2",
    "@mercurjs/cli": "2.1.6",
    "@mercurjs/core": "2.1.6",
    "@mercurjs/types": "2.1.6",
    "http-proxy-middleware": "^3.0.3",
    "ioredis": "^5.4.1",
    "multer": "^2.2.0",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@medusajs/test-utils": "2.17.2",
    "@swc/core": "^1.15.43",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^29.5.13",
    "@types/multer": "^2.2.0",
    "@types/node": "^20.12.11",
    "jest": "^29.7.0",
    "pg-god": "^1.0.12",
    "prop-types": "^15.8.1",
    "yalc": "^1.0.0-pre.53"
  },
  "engines": {
    "node": ">=20"
  }
}
